# ==========================================================================
# SANARIO PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to a new file named '.env' and fill in your variables.
# ==========================================================================

# Port the server listens on in production
PORT=3000

# Environment state
NODE_ENV=production

# --------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION
# --------------------------------------------------------------------------
# Leave empty to automatically use the file-backed SQLite database (local dev).
# For cloud deployment (Render, Heroku, Supabase, Neon), supply your PostgreSQL URI.
DATABASE_URL=postgres://username:password@hostname:5432/databasename

# --------------------------------------------------------------------------
# 2. SESSION SECURITY
# --------------------------------------------------------------------------
# A secure, random string used to encrypt JWT user login sessions.
JWT_SECRET=super_secure_random_hash_change_this_in_production

# --------------------------------------------------------------------------
# 3. GOOGLE SIGN-IN OAUTH SETUP
# --------------------------------------------------------------------------
# Obtained from Google Cloud Console -> APIs & Services -> Credentials.
# If left empty, the application falls back to a simulated developer login chooser.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
